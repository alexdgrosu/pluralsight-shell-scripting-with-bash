#!/bin/bash

# Prints standard input to standard ouput
# discarding all lines before the first line matching
# the string given as the first argument

if [[ ! $1 ]]; then
    echo "Need first argument" >&2
    exit 1
fi

while read -r; do
    if [[ $REPLY =~ $1 ]]; then
        echo "$REPLY"
        break
    fi
done

while read -r || [[ $REPLY ]]; do
    echo "$REPLY"
done

exit 0