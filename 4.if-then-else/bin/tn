#!/bin/bash

# Get the date
date=$(date)

# Get the topic
topic="$1"

# File to write to
filename="${topic}notes.txt"

# Ask for user input
read -p "Your note: " note

if [[ $note ]]; then
    echo "$date: $note" >> "$filename"
    echo "Note '$note' saved to $filename"
else 
    echo "No input; note wasn't saved"
fi


